<%- include('partials/header') %>
    <style>
        .auth_wrap {
            max-width: 450px;
            margin: 80px auto;
            padding: 0 20px;
        }

        .auth_box {
            background: #fff;
            padding: 40px;
            border-radius: 20px;
            border: 1px solid #eee;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        }

        .auth_title {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 30px;
            text-align: center;
        }

        .form_field {
            margin-bottom: 20px;
        }

        .form_field label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #666;
            margin-bottom: 8px;
        }

        .form_field input {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 10px;
            outline: none;
            transition: 0.3s;
        }

        .form_field input:focus {
            border-color: #ff4d4d;
        }

        .check_line {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 25px;
            padding: 0 5px;
        }

        .check_line input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #2563eb;

        }

        .check_line label {
            font-size: 14px;
            color: #666;
            cursor: pointer;
            user-select: none;
            line-height: 1.2;
        }

        .check_line label a {
            color: #666;
            text-decoration: none;
        }

        .check_line label a:hover {
            text-decoration: underline;
        }

        .btn_auth {
            width: 100%;
            padding: 14px;
            background: #ff4d4d;
            color: #fff;
            border: none;
            border-radius: 10px;
            font-weight: bold;
            font-size: 16px;
            cursor: pointer;
        }

        .form_error {
            background: #fef2f2;
            color: #dc2626;
            padding: 10px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            text-align: center;
        }

        .auth_links {
            text-align: center;
            margin-top: 25px;
            font-size: 14px;
            color: #888;
        }

        .auth_links a {
            color: #ff4d4d;
            text-decoration: none;
            font-weight: 600;
        }
    </style>

    <div class="auth_wrap">
        <div class="auth_box">
            <h1 class="auth_title">Создать аккаунт</h1>

            <% if (error) { %>
                <div class="form_error">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/register" method="POST">
                        <div class="form_field">
                            <label>Ваше имя</label>
                            <input type="text" name="name" placeholder="Как вас зовут?" required>
                        </div>
                        <div class="form_field">
                            <label>Электронная почта</label>
                            <input type="email" name="email" placeholder="example@mail.ru" required>
                        </div>
                        <div class="form_field">
                            <label>Пароль</label>
                            <input type="password" name="password" placeholder="Придумайте пароль" required>
                        </div>
                        <div class="form_field">
                            <label>Повторите пароль</label>
                            <input type="password" name="confirmPassword" placeholder="Еще раз пароль" required>
                        </div>
                        <div class="check_line">
                            <input type="checkbox" name="agreement" id="agreement" required>
                            <label for="agreement">
                                Я согласен на обработку персональных данных
                            </label>
                        </div>
                        <button type="submit" class="btn_auth">Зарегистрироваться</button>
                    </form>

                    <div class="auth_links">
                        Уже есть аккаунт? <a href="/login">Войти</a>
                    </div>
        </div>
    </div>
    <%- include('partials/footer') %>