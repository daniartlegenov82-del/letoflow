<style>
    body {
        background-color: #FDFDFD;
        font-weight: 400;
        color: #1a1a1a;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
        font-weight: 700 !important;
        color: #1a1a1a;
        margin: 0;
    }

    .site_header {
        background: #fff;
        border-bottom: 1px solid #f0f0f0;
        position: sticky;
        top: 0;
        z-index: 1000;
        padding: 20px 0;
    }

    .header_inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 30px;
    }

    .nav_main {
        display: flex;
        align-items: center;
        gap: 25px;
    }

    .logo {
        color: #ff4d4d;
        font-size: 28px;
        font-weight: 700;
        text-decoration: none;
        letter-spacing: -0.5px;
    }

    .nav_link {
        background: transparent;
        color: #1a1a1a;
        text-decoration: none;
        font-weight: 400;
        font-size: 15px;
        display: flex;
        align-items: center;
        transition: all 0.2s;
    }

    .nav_link:hover {
        color: #ff4d4d;
    }

    .is_here {
        color: #ff4d4d !important;
        font-weight: 700 !important;
    }

    .user_area {
        display: flex;
        align-items: center;
        gap: 20px;
    }
</style>
<script src="https://cdn.tailwindcss.com"></script>

<div class="site_header">
    <div class="header_inner">
        <div class="nav_main">
            <a href="/" class="logo">LetoFlowers</a>

            <a href="/catalog" class="nav_link <%= path === '/catalog' ? 'is_here' : '' %>">Каталог</a>
            <a href="/custom-order"
                class="nav_link <%= path === '/custom-order' ? 'is_here' : '' %>">Заказ букета</a>
            <% if (user && user.role==='user' ) { %>
                <a href="/account" class="nav_link <%= path === '/account' ? 'is_here' : '' %>">Личный
                    кабинет</a>
                <% } %>
                    <a href="/about" class="nav_link <%= path === '/about' ? 'is_here' : '' %>">О нас</a>
            <a href="/reviews" class="nav_link <%= path === '/reviews' ? 'is_here' : '' %>">Отзывы</a>
            <a href="/contacts" class="nav_link <%= path === '/contacts' ? 'is_here' : '' %>">Контакты</a>
        </div>

        <div class="user_area">

            <% if (user) { %>
                <% if (user.role==='admin' ) { %>
                    <a href="/admin" class="nav_link <%= path === '/admin' ? 'is_here' : '' %>"
                        style="text-decoration: underline; font-size: 13px;">Админка</a>
                    <% } %>
                        <a href="/logout" style="font-size: 13px; color: #aaa; text-decoration: none;">Выйти</a>
                        <% const hdrAvatar=(user.avatarUrl && String(user.avatarUrl).trim()) || '' ; %>
                            <% if (user.role==='user' ) { %>
                                <a href="/account" title="Личный кабинет"
                                    class="<%= path === '/account' ? 'is_here' : '' %>"
                                    style="display:flex;align-items:center;text-decoration:none;border-radius:50%;outline:none;">
                                    <% } %>
                                        <% if (hdrAvatar && (hdrAvatar.toLowerCase().startsWith('http://') || hdrAvatar.toLowerCase().startsWith('https://'))) { %>
                                            <img src="<%= hdrAvatar %>" alt=""
                                                style="width:32px;height:32px;border-radius:50%;object-fit:cover;border:1px solid #eee;display:block;"
                                                referrerpolicy="no-referrer">
                                            <% } else { %>
                                                <div
                                                    style="width: 32px; height: 32px; background: #f5f5f7; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; border: 1px solid #eee; color:#1a1a1a;">
                                                    <%= user.name && user.name[0] ? user.name[0].toUpperCase() : '?' %>
                                                </div>
                                                <% } %>
                                                    <% if (user.role==='user' ) { %>
                                </a>
                                <% } %>
                        <% } else { %>
                            <a href="/login" class="<%= path === '/login' ? 'is_here' : '' %>"
                                style="color: #1a1a1a;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="1.5">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                    <circle cx="12" cy="7" r="4" />
                                </svg></a>
                            <% } %>
        </div>
    </div>
</div>